<?xml version="1.0" encoding="UTF-8"?>
<idea-plugin>
    <id>com.flora.ramet</id>
    <name>Ramet 模板语言支持</name>
    <version>0.5</version>
    <vendor>flora</vendor>

    <icon main="pluginIcon.svg"/>

    <description><![CDATA[
      <h3>Ramet 模板引擎语言支持</h3>
      <p>为 <code>.ramet</code> 文件提供两级细粒度语法高亮。</p>
      <h4>功能</h4>
      <ul>
        <li>模板指令关键字、操作符、字符串、数字、函数分区着色</li>
        <li>被动文本暗淡低饱和度，逻辑块鲜艳高饱和度</li>
        <li>Meta 块 (@Param/@Cartesian/@Path/@Config/@SkipWhen) 完整语法高亮</li>
        <li>文件气泡镶嵌图标</li>
      </ul>
    ]]></description>

    <change-notes><![CDATA[
      <h4>v0.6</h4>
      <ul>
        <li>新增 continue/break/meta 指令语法高亮支持</li>
        <li>Meta 块 (@Param/@Cartesian/@Path/@Config/@SkipWhen) 完整 Lson 语法高亮</li>
        <li>逻辑块内标识符亮色、被动块灰色</li>
        <li>移除引用跳转功能，专注语法高亮</li>
      </ul>
    ]]></change-notes>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <lang.parserDefinition
                language="Ramet"
                implementationClass="com.flora.ramet.idea.parser.RametParserDefinition"/>

        <fileTypeRegistrar
                implementation="com.flora.ramet.idea.RametFileTypeRegistrar"/>

        <lang.syntaxHighlighterFactory
                language="Ramet"
                implementationClass="com.flora.ramet.idea.highlighter.RametSyntaxHighlighterFactory"/>

        <colorSettingsPage
                implementation="com.flora.ramet.idea.highlighter.RametColorSettingsPage"/>

        <annotator
                language="Ramet"
                implementationClass="com.flora.ramet.idea.highlighter.RametAnnotator"/>

        <additionalTextAttributes
                scheme="Default"
                file="colorSchemes/RametDefault.xml"/>
    </extensions>
</idea-plugin>
