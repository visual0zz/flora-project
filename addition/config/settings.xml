<?xml version="1.0" encoding="UTF-8"?>
<settings xmlns="http://maven.apache.org/SETTINGS/1.0.0"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/SETTINGS/1.0.0
                              https://maven.apache.org/xsd/settings-1.0.0.xsd">
    <profiles>
        <profile>
            <id>demiurge-repos</id>
            <repositories>
                <repository>
                    <id>aliyun</id>
                    <name>Aliyun Maven Repository</name>
                    <url>https://maven.aliyun.com/repository/public</url>
                </repository>
                <repository>
                    <id>tuna</id>
                    <name>Tsinghua TUNA Maven Mirror</name>
                    <url>https://maven.tuna.tsinghua.edu.cn/repository/public</url>
                </repository>
                <repository>
                    <id>huaweicloud</id>
                    <name>HuaweiCloud Maven Mirror</name>
                    <url>https://repo.huaweicloud.com/repository/maven</url>
                </repository>
                <repository>
                    <id>central</id>
                    <name>Maven Central</name>
                    <url>https://repo1.maven.org/maven2</url>
                </repository>
                <repository>
                    <id>jtexpress</id>
                    <name>JTExpress Nexus</name>
                    <url>http://maven.jtexpress.com.cn/nexus/content/groups/public</url>
                </repository>
            </repositories>
            <pluginRepositories>
                <pluginRepository>
                    <id>aliyun</id>
                    <name>Aliyun Maven Repository</name>
                    <url>https://maven.aliyun.com/repository/public</url>
                </pluginRepository>
                <pluginRepository>
                    <id>tuna</id>
                    <name>Tsinghua TUNA Maven Mirror</name>
                    <url>https://maven.tuna.tsinghua.edu.cn/repository/public</url>
                </pluginRepository>
                <pluginRepository>
                    <id>huaweicloud</id>
                    <name>HuaweiCloud Maven Mirror</name>
                    <url>https://repo.huaweicloud.com/repository/maven</url>
                </pluginRepository>
                <pluginRepository>
                    <id>central</id>
                    <name>Maven Central</name>
                    <url>https://repo1.maven.org/maven2</url>
                </pluginRepository>
                <pluginRepository>
                    <id>jtexpress</id>
                    <name>JTExpress Nexus</name>
                    <url>http://maven.jtexpress.com.cn/nexus/content/groups/public</url>
                </pluginRepository>
            </pluginRepositories>
        </profile>
    </profiles>
    <activeProfiles>
        <activeProfile>demiurge-repos</activeProfile>
    </activeProfiles>
</settings>
